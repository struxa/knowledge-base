{% extends '@plugin_knowledge_base_plugin/admin/_layout.twig' %}

{% block admin_title %}Knowledge Base{% endblock %}

{% block admin_hero_title %}
  <h1 class="admin-hero-title">Knowledge Base</h1>
{% endblock %}

{% block admin_hero_sub %}
  <p class="admin-hero-sub">
    Struxa CMS documentation for your team. Pick an article from the sidebar, or browse by section below.
    {% if public_visible %}
      Published on the storefront at <code>/{{ content_type_slug }}/…</code>.
    {% else %}
      Admin-only until you enable the storefront in Settings.
    {% endif %}
  </p>
{% endblock %}

{% block admin_hero_actions %}
  {% if public_visible %}
    <a class="admin-btn admin-btn--primary" href="/{{ content_type_slug }}" target="_blank" rel="noopener">View public index</a>
  {% endif %}
{% endblock %}

{% block kb_wiki_main %}
  <section class="admin-section" style="padding-top: 0;">
    <div class="admin-cards" style="margin-bottom: 1.25rem;">
      <article class="admin-card admin-card--featured">
        <div class="admin-card-body">
          <p class="admin-card-kicker">Articles</p>
          <p class="admin-card-stat">{{ article_count }}</p>
          <p class="admin-card-desc">Grouped by audience in the sidebar. Content is stored as the <code>kb</code> content type.</p>
        </div>
      </article>
      <article class="admin-card">
        <div class="admin-card-body">
          <p class="admin-card-kicker">Storefront</p>
          <p class="admin-card-stat">{{ public_visible ? 'Public' : 'Admin only' }}</p>
          <p class="admin-card-desc">
            {% if public_visible %}
              Public routes enabled for <code>{{ content_type_slug }}</code>.
            {% else %}
              Enable <strong>Visible on storefront</strong> in Settings to expose public URLs.
            {% endif %}
          </p>
        </div>
      </article>
    </div>

    {% if sections is empty %}
      <div class="admin-callout">
        <p class="admin-prose">No articles yet. Activate the plugin (migrations) and reload this page to seed the default wiki.</p>
      </div>
    {% else %}
      <div class="kb-wiki-section-cards">
        {% for section in sections %}
          <article class="kb-wiki-section-card">
            <h3>{{ section.section_label|e }}</h3>
            <p>{{ section.articles|length }} article{{ section.articles|length == 1 ? '' : 's' }}</p>
            <ul>
              {% for article in section.articles|slice(0, 5) %}
                <li><a href="{{ article.read_url }}">{{ article.title|e }}</a></li>
              {% endfor %}
              {% if section.articles|length > 5 %}
                <li class="admin-text-muted">+ {{ section.articles|length - 5 }} more in sidebar</li>
              {% endif %}
            </ul>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </section>
{% endblock %}
